{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@barberly/shared-ui": ["libs/shared-ui/src/index.ts"],
      "@barberly/shared-models": ["libs/shared-models/src/index.ts"],
      "@barberly/shared-auth": ["libs/shared-auth/src/index.ts"],
      "@barberly/shared-utils": ["libs/shared-utils/src/index.ts"]
    },
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "exclude": ["node_modules", "tmp"]
}
